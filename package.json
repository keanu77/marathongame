{
  "name": "marathon-prep-runner",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "從馬拉松基礎期、進階期到正式比賽的繁體中文 2D 跑酷衛教遊戲。",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p functions/tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:migrate:local": "wrangler d1 migrations apply marathongame-leaderboard --local",
    "db:migrate:remote": "wrangler d1 migrations apply marathongame-leaderboard --remote",
    "dev:cloudflare": "wrangler pages dev",
    "build:functions": "wrangler pages functions build --outdir .wrangler/functions-build",
    "check": "pnpm typecheck && pnpm lint && pnpm format && pnpm test && pnpm build"
  },
  "dependencies": {
    "phaser": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.2.7",
    "vitest": "^4.0.16",
    "wrangler": "^4.110.0"
  }
}
